#include <iostream>
using namespace std;
int main() {
    int a, b;
    cout << "Enter two numbers: ";
    cin >> a >> b;
    cout << "Addition = " << a + b << "\n";
    cout << "Subtraction = " << a - b << "\n";
    cout << "Multiplication = " << a * b << "\n";
    cout << "Division = " << a / b;
    return 0;
}
